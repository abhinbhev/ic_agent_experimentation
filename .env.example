# OpenAI (used directly if no LiteLLM proxy is configured below)
OPENAI_API_KEY=

# Optional overrides
IC_AGENT_OPENAI_MODEL=gpt-5.4
IC_AGENT_EMBEDDING_MODEL=text-embedding-3-small

# Embedding backend: "openai" (default) or "ollama"
IC_AGENT_EMBEDDING_BACKEND=openai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Logging
IC_AGENT_LOG_LEVEL=INFO

# Paths (relative to project root)
IC_AGENT_CORPUS_PATH=corpus/similar_plans.yaml
IC_AGENT_DOMAIN_DIR=config/domains
IC_AGENT_PROBE_BUDGET_PATH=config/probe_budget.yaml
IC_AGENT_USECASE_DOCS_DIR=docs/metadata

# LiteLLM proxy (Azure OpenAI-compatible). If set, chat + embeddings are
# routed through this proxy instead of OpenAI directly.
AZURE_OPENAI_ENDPOINT_LITELLM=
AZURE_OPENAI_API_KEY_LITELLM=
AZURE_OPENAI_API_VERSION_LITELLM=

# Retrieval Layer (analysis_template_svc). "http" calls the real service
# at IC_AGENT_RETRIEVAL_BASE_URL; "mock" returns canned answers.
IC_AGENT_RETRIEVAL_MODE=http
IC_AGENT_RETRIEVAL_BASE_URL=http://localhost:7777
IC_AGENT_RETRIEVAL_USER_ID=agentic_experiment
INTERNAL_API_KEY=
